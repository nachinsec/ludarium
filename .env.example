# Copy to .env and adjust.

# Public base URL — must match how the browser reaches the app.
# Used as the Steam OpenID realm and callback origin.
BASE_URL=http://localhost:3000

# Port the Go server listens on.
PORT=3000

# Required in production. In dev an ephemeral secret is generated if empty.
SESSION_SECRET=

# Server-side Steam Web API key (https://steamcommunity.com/dev/apikey).
# Optional for login; required to import libraries and fetch profiles.
STEAM_API_KEY=

# SQLite file location.
DB_PATH=./data/ludarium.db

# AI recommendations (any OpenAI-compatible endpoint).
# OpenAI:  AI_BASE_URL=https://api.openai.com/v1  AI_MODEL=gpt-4o-mini
# Ollama:  AI_BASE_URL=http://localhost:11434/v1  AI_MODEL=llama3.1  AI_API_KEY=ollama
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# IGDB (game metadata) — register a Twitch app at https://dev.twitch.tv/console/apps
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# Set to "development" to relax cookie Secure flag and auto-generate secrets.
ENV=development
